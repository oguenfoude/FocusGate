<Window x:Class="FocusGate.Desktop.Views.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="FocusGate" Width="400" Height="260"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True">
    <Border Background="#09090b" CornerRadius="12"
            BorderBrush="#27272a" BorderThickness="1">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,16,0,0">
                <ui:SymbolIcon Symbol="Shield24" FontSize="36" Foreground="#fafafa" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="FocusGate" FontSize="24" FontWeight="SemiBold"
                           Foreground="#fafafa" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock x:Name="StatusText" Text="Starting..." FontSize="13"
                           Foreground="#71717a" HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,12">
                <ProgressBar x:Name="ProgressBar" IsIndeterminate="True" Width="200" Height="3"
                             Foreground="#10b981" Background="#27272a"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

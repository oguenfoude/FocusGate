@page
@model FocusGate.Dashboard.Pages.ModemDetailModel
@{
    ViewData["Title"] = L["ModemDetail.Title"];
}

<!-- Back link -->
<a href="/Modems" class="inline-flex items-center gap-1.5 text-xs text-gray-400 hover:text-brand-500 mb-4 transition-colors">
    <i class="fas fa-arrow-left"></i> @L["ModemDetail.Back"]
</a>

@if (Model.Modem == null)
{
    <div class="card p-12 text-center">
        <i class="fas fa-exclamation-triangle text-gray-300 text-3xl mb-3"></i>
        <p class="text-gray-400">@L["ModemDetail.NotFound"]</p>
    </div>
}
else
{
    <!-- Header card -->
    <div class="card mb-5">
        <div class="card-body flex items-center gap-5">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center flex-shrink-0 @(Model.Modem.Status == FocusGate.Core.Enums.ModemStatus.Online ? "bg-brand-50" : "bg-gray-100")">
                <i class="fas fa-tower-broadcast text-xl @(Model.Modem.Status == FocusGate.Core.Enums.ModemStatus.Online ? "text-brand-500" : "text-gray-400")"></i>
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3">
                    <h3 class="text-lg font-bold text-gray-900">@(Model.Sim != null ? Model.Sim.PhoneNumber : Model.Modem.IMEI)</h3>
                    @if (Model.Modem.Status == FocusGate.Core.Enums.ModemStatus.Online)
                    {
                        <span class="badge badge-success"><span class="pulse-dot relative" style="width:5px;height:5px;"></span> @L["Common.Online"]</span>
                    }
                    else
                    {
                        <span class="badge badge-danger">@L["Common.Offline"]</span>
                    }
                </div>
                <p class="text-xs text-gray-400 mt-1">@Model.Modem.Brand @Model.Modem.Model &middot; @(Model.Modem.ComPort ?? "N/A") &middot; @Model.Modem.MachineId?[..8]</p>
            </div>
            @if (Model.Sim != null)
            {
                <div class="text-right flex-shrink-0">
                    <p class="text-2xl font-bold text-brand-600">@Model.Sim.Balance.ToString("N2") DA</p>
                    <p class="text-xs font-mono text-gray-400 mt-0.5">IMEI: @Model.Modem.IMEI</p>
                </div>
            }
        </div>
    </div>

    <!-- Tabs -->
    <div x-data="{ tab: 'info' }">
        <div class="flex gap-0 border-b border-gray-200 mb-5">
            <button @@click="tab = 'info'" :class="tab === 'info' ? 'border-brand-500 text-brand-600' : 'border-transparent text-gray-400 hover:text-gray-600'"
                    class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px">
                <i class="fas fa-info-circle mr-1.5"></i> @L["ModemDetail.InfoTab"]
            </button>
            <button @@click="tab = 'balance'" :class="tab === 'balance' ? 'border-brand-500 text-brand-600' : 'border-transparent text-gray-400 hover:text-gray-600'"
                    class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px">
                <i class="fas fa-chart-line mr-1.5"></i> @L["ModemDetail.BalanceTab"]
            </button>
            <button @@click="tab = 'sms'" :class="tab === 'sms' ? 'border-brand-500 text-brand-600' : 'border-transparent text-gray-400 hover:text-gray-600'"
                    class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px">
                <i class="fas fa-comment mr-1.5"></i> @L["ModemDetail.SmsTab"]
                <span class="ml-1 text-[10px] bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded-full">@Model.SmsCount</span>
            </button>
        </div>

        <!-- Info Tab -->
        <div x-show="tab === 'info'" x-transition>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
                <!-- Modem Info -->
                <div class="card">
                    <div class="card-header"><h4 class="text-sm font-semibold text-gray-900">@L["ModemDetail.InfoTitle"]</h4></div>
                    <div class="card-body">
                        <dl class="grid grid-cols-2 gap-4 text-sm">
                            <div>
                                <dt class="text-[11px] text-gray-400 uppercase tracking-wider font-medium">IMEI</dt>
                                <dd class="font-mono text-sm font-medium mt-1">@Model.Modem.IMEI</dd>
                            </div>
                            <div>
                                <dt class="text-[11px] text-gray-400 uppercase tracking-wider font-medium">ComPort</dt>
                                <dd class="text-sm font-medium mt-1">@(Model.Modem.ComPort ?? "N/A")</dd>
                            </div>
                            <div>
                                <dt class="text-[11px] text-gray-400 uppercase tracking-wider font-medium">@L["Modems.Device"]</dt>
                                <dd class="text-sm font-medium mt-1">@Model.Modem.Brand @Model.Modem.Model</dd>
                            </div>
                            <div>
                                <dt class="text-[11px] text-gray-400 uppercase tracking-wider font-medium">@L["Common.Created"]</dt>
                                <dd class="text-sm font-medium mt-1">@Model.Modem.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</dd>
                            </div>
                            <div class="col-span-2">
                                <dt class="text-[11px] text-gray-400 uppercase tracking-wider font-medium">@L["ModemDetail.MachineId"]</dt>
                                <dd class="font-mono text-xs mt-1 text-gray-500 truncate" title="@Model.Modem.MachineId">@Model.Modem.MachineId</dd>
                            </div>
                        </dl>
                    </div>
                </div>

                <!-- SIM Card -->
                @if (Model.Sim != null)
                {
                    <div class="card">
                        <div class="card-header"><h4 class="text-sm font-semibold text-gray-900">@L["ModemDetail.SimCard"]</h4></div>
                        <div class="card-body">
                            <dl class="space-y-3 text-sm">
                                <div class="flex justify-between">
                                    <dt class="text-gray-400">@L["ModemDetail.Imsi"]</dt>
                                    <dd class="font-mono font-medium">@Model.Sim.IMSI</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-gray-400">@L["ModemDetail.Phone"]</dt>
                                    <dd class="font-medium">@Model.Sim.PhoneNumber</dd>
                                </div>
                                <div class="flex justify-between items-center">
                                    <dt class="text-gray-400">@L["Common.Balance"]</dt>
                                    <dd class="text-lg font-bold text-brand-600">@Model.Sim.Balance.ToString("N2") DA</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-gray-400">@L["Common.Status"]</dt>
                                    <dd><span class="badge @(Model.Sim.IsActive ? "badge-success" : "badge-gray")">@(Model.Sim.IsActive ? L["Users.Active"] : L["Users.Archived"])</span></dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-gray-400">@L["ModemDetail.FirstSeen"]</dt>
                                    <dd class="text-xs">@Model.Sim.FirstSeen.ToLocalTime().ToString("MMM dd, yyyy")</dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-gray-400">@L["Modems.LastSeen"]</dt>
                                    <dd class="text-xs">@Model.Sim.LastSeen.ToLocalTime().ToString("MMM dd, HH:mm")</dd>
                                </div>
                            </dl>

                            <div class="mt-4 pt-4 border-t border-gray-100">
                                <p class="text-[11px] text-gray-400 uppercase tracking-wider font-medium mb-2">@L["ModemDetail.AssignedUser"]</p>
                                @if (Model.AssignedUser != null)
                                {
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-2">
                                            <div class="w-7 h-7 bg-purple-100 text-purple-600 rounded-full flex items-center justify-center text-[10px] font-bold">@Model.AssignedUser.Username[0]</div>
                                            <span class="text-sm font-medium">@Model.AssignedUser.Username</span>
                                        </div>
                                        <button hx-post="/ModemDetail?handler=Unassign&modemId=@Model.Modem.Id"
                                                hx-confirm="Unassign this modem?"
                                                hx-swap="none"
                                                class="text-xs text-red-400 hover:text-red-500">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <p class="text-xs text-gray-300">@L["ModemDetail.NoUserAssigned"]</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Balance History Tab -->
        <div x-show="tab === 'balance'" x-transition>
            <div class="card">
                <div class="card-body max-h-[500px] overflow-y-auto">
                    @if (Model.BalanceHistory.Any())
                    {
                        <div class="space-y-0">
                            @foreach (var b in Model.BalanceHistory)
                            {
                                <div class="flex gap-4 relative pb-5">
                                    <!-- Timeline line -->
                                    <div class="absolute left-[11px] top-6 bottom-0 w-px bg-gray-100"></div>
                                    <!-- Dot -->
                                    <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 z-10
                                        @(b.Source == FocusGate.Core.Enums.BalanceSource.USSD ? "bg-blue-50 text-blue-500" :
                                          b.Source == FocusGate.Core.Enums.BalanceSource.SMS ? "bg-brand-50 text-brand-500" :
                                          b.Source == FocusGate.Core.Enums.BalanceSource.Withdrawal ? "bg-red-50 text-red-500" :
                                          "bg-gray-100 text-gray-500")">
                                        <i class="fas @(b.Source == FocusGate.Core.Enums.BalanceSource.USSD ? "fa-signal" :
                                                       b.Source == FocusGate.Core.Enums.BalanceSource.SMS ? "fa-comment" :
                                                       b.Source == FocusGate.Core.Enums.BalanceSource.Withdrawal ? "fa-minus-circle" :
                                                       "fa-circle") text-[10px]"></i>
                                    </div>
                                    <!-- Content -->
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-baseline justify-between">
                                            <span class="font-semibold text-sm">@b.Balance.ToString("N2") DA</span>
                                            <span class="text-gray-400 text-[11px]">@b.RecordedAt.ToLocalTime().ToString("MMM dd, HH:mm")</span>
                                        </div>
                                        <p class="text-xs text-gray-400 mt-0.5">
                                            @b.Source
                                            @if (b.PreviousBalance.HasValue)
                                            {
                                                <span class="text-gray-300"> &middot; was @b.PreviousBalance.Value.ToString("N2") DA</span>
                                            }
                                        </p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="py-12 text-center">
                            <i class="fas fa-chart-line text-gray-200 text-3xl mb-2"></i>
                            <p class="text-sm text-gray-400">@L["Common.NoData"]</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- SMS Tab -->
        <div x-show="tab === 'sms'" x-transition>
            <div class="card">
                <div class="card-header flex items-center justify-between">
                    <h4 class="text-sm font-semibold text-gray-900">@L["ModemDetail.SmsMessages"]</h4>
                    <span class="text-[11px] text-gray-400">@Model.SmsCount total</span>
                </div>
                <div class="max-h-[500px] overflow-y-auto">
                    @if (Model.SmsRecords.Any())
                    {
                        <div class="divide-y divide-gray-50">
                            @foreach (var sms in Model.SmsRecords)
                            {
                                <div class="px-5 py-4 table-row">
                                    <div class="flex gap-3">
                                        <div class="w-8 h-8 bg-brand-50 text-brand-600 rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0 mt-0.5">
                                            @(sms.SenderNumber.Length >= 2 ? sms.SenderNumber[^2..] : sms.SenderNumber)
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center gap-2 mb-1">
                                                <span class="text-sm font-semibold text-gray-900">@sms.SenderNumber</span>
                                                <span class="text-[10px] text-gray-300">&middot;</span>
                                                <span class="text-[11px] text-gray-400">@sms.ReceivedAt.ToLocalTime().ToString("MMM dd, HH:mm")</span>
                                            </div>
                                            <p class="text-sm text-gray-600 leading-relaxed">@sms.Content</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="py-12 text-center">
                            <i class="fas fa-comment text-gray-200 text-3xl mb-2"></i>
                            <p class="text-sm text-gray-400">@L["ModemDetail.NoSms"]</p>
                        </div>
                    }
                </div>
                @if (Model.SmsCount > 20)
                {
                    <div class="px-5 py-2.5 border-t border-gray-100 text-center">
                        <span class="text-[11px] text-gray-400">@L["ModemDetail.Showing"] 20 @L["ModemDetail.Of"] @Model.SmsCount</span>
                    </div>
                }
            </div>
        </div>
    </div>
}


@page
@model FocusGate.Dashboard.Pages.UserDetailModel
@{
    ViewData["Title"] = L["UserDetail.Title"];
}

<!-- Back link -->
<a href="/Users" class="inline-flex items-center gap-1.5 text-xs text-gray-400 hover:text-brand-500 mb-4 transition-colors">
    <i class="fas fa-arrow-left"></i> @L["UserDetail.Back"]
</a>

@if (Model.User == null)
{
    <div class="card p-12 text-center">
        <i class="fas fa-exclamation-triangle text-gray-300 text-3xl mb-3"></i>
        <p class="text-gray-400">@L["UserDetail.NotFound"]</p>
    </div>
}
else
{
    <!-- Header card -->
    <div class="card mb-5">
        <div class="card-body flex items-center gap-5">
            <div class="w-14 h-14 bg-brand-50 text-brand-600 rounded-xl flex items-center justify-center text-xl font-bold flex-shrink-0">
                @Model.User.Username[0]
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3">
                    <h3 class="text-lg font-bold text-gray-900">@Model.User.Username</h3>
                    <span class="badge @(Model.User.Role == FocusGate.Core.Enums.UserRole.Admin ? "badge-purple" : "badge-gray")">@Model.User.Role</span>
                    @if (Model.User.ArchivedAt != null)
                    {
                        <span class="badge badge-gray">@L["Users.Archived"]</span>
                    }
                </div>
                <p class="text-xs text-gray-400 mt-1">@Model.User.DisplayName &middot; @L["UserDetail.Since"] @Model.User.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</p>
            </div>
            <div class="flex items-center gap-3 flex-shrink-0">
                @if (Model.User.Role != FocusGate.Core.Enums.UserRole.Admin)
                {
                    <button onclick="document.getElementById('editUserDetailModal').classList.remove('hidden')"
                            class="btn btn-outline text-xs">
                        <i class="fas fa-pen mr-1"></i> @L["Users.EditUser"]
                    </button>
                }
                <div class="text-right">
                    <p class="text-xs text-gray-400">@L["UserDetail.WalletBalance"]</p>
                    <p class="text-2xl font-bold text-brand-600 mt-0.5">@Model.User.Balance.ToString("N2") DA</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <div x-data="{ tab: 'modems' }">
        <div class="flex gap-0 border-b border-gray-200 mb-5">
            <button @@click="tab = 'modems'" :class="tab === 'modems' ? 'border-brand-500 text-brand-600' : 'border-transparent text-gray-400 hover:text-gray-600'"
                    class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px">
                <i class="fas fa-tower-broadcast mr-1.5"></i> @L["Nav.Modems"]
                <span class="ml-1 text-[10px] bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded-full">@Model.AssignedModems.Count</span>
            </button>
            <button @@click="tab = 'wallet'" :class="tab === 'wallet' ? 'border-brand-500 text-brand-600' : 'border-transparent text-gray-400 hover:text-gray-600'"
                    class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px">
                <i class="fas fa-wallet mr-1.5"></i> @L["UserDetail.WalletTab"]
            </button>
            <button @@click="tab = 'history'" :class="tab === 'history' ? 'border-brand-500 text-brand-600' : 'border-transparent text-gray-400 hover:text-gray-600'"
                    class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px">
                <i class="fas fa-clock mr-1.5"></i> @L["UserDetail.HistoryTab"]
            </button>
            <button @@click="tab = 'sms'" :class="tab === 'sms' ? 'border-brand-500 text-brand-600' : 'border-transparent text-gray-400 hover:text-gray-600'"
                    class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px">
                <i class="fas fa-envelope mr-1.5"></i> @L["ModemDetail.SmsTab"]
                <span class="ml-1 text-[10px] bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded-full">@Model.SmsMessages.Count</span>
            </button>
        </div>

        <!-- Modems Tab -->
        <div x-show="tab === 'modems'" x-transition>
            <div class="card">
                <div class="card-header flex items-center justify-between">
                    <h4 class="text-sm font-semibold text-gray-900">@L["UserDetail.AssignedModems"]</h4>
                </div>
                <div class="card-body">
                    @if (Model.AssignedModems.Any())
                    {
                        <div class="space-y-2 mb-4">
                            @foreach (var m in Model.AssignedModems)
                            {
                                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                    <a href="/ModemDetail?id=@m.ModemId" class="flex items-center gap-3 flex-1 min-w-0">
                                        <div class="w-9 h-9 bg-brand-50 text-brand-600 rounded-lg flex items-center justify-center flex-shrink-0">
                                            <i class="fas fa-signal text-xs"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <p class="text-sm font-medium text-gray-900 truncate">@m.PhoneNumber</p>
                                            <p class="text-[11px] font-mono text-gray-400">IMEI: @m.Imei &middot; @m.Balance.ToString("N2") DA</p>
                                        </div>
                                    </a>
                                    <button hx-post="/UserDetail?handler=UnassignModem&modemId=@m.ModemId&userId=@Model.User.Id"
                                            hx-confirm="@L["Modems.Unassign"] @m.PhoneNumber?"
                                            hx-swap="none"
                                            class="p-2 text-red-300 hover:text-red-500 rounded-lg hover:bg-red-50 transition-colors">
                                        <i class="fas fa-times text-xs"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="py-8 text-center">
                            <i class="fas fa-tower-broadcast text-gray-200 text-2xl mb-2"></i>
                            <p class="text-sm text-gray-400">@L["UserDetail.NoModems"]</p>
                        </div>
                    }

                    <!-- Assign form -->
                    <div class="pt-4 border-t border-gray-100">
                        <p class="text-[11px] text-gray-400 uppercase tracking-wider font-medium mb-2">@L["UserDetail.AssignNew"]</p>
                        <form hx-post="/UserDetail?handler=AssignModem&userId=@Model.User.Id"
                              hx-swap="none"
                              class="flex gap-2">
                            <select name="modemId" required class="input flex-1">
                                <option value="">@L["UserDetail.SelectModem"]</option>
                                @foreach (var m in Model.AvailableModems)
                                {
                                    <option value="@m.Id">@m.PhoneNumber (IMEI: @m.Imei)</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-primary">@L["UserDetail.Assign"]</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Wallet Tab -->
        <div x-show="tab === 'wallet'" x-transition>
            <div class="card">
                <div class="card-body text-center py-10">
                    <p class="text-xs text-gray-400 uppercase tracking-wider font-medium">@L["UserDetail.CurrentBalance"]</p>
                    <p class="text-5xl font-bold text-brand-600 mt-3">@Model.User.Balance.ToString("N2")</p>
                    <p class="text-sm text-gray-400 mt-1">DZD</p>

                    <div class="mt-8 pt-6 border-t border-gray-100">
                        <button onclick="document.getElementById('withdrawalModal').classList.remove('hidden')"
                                class="btn btn-primary px-8">
                            <i class="fas fa-money-bill-wave"></i> @L["UserDetail.CreateWithdrawal"]
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- History Tab -->
        <div x-show="tab === 'history'" x-transition>
            <div class="card">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-gray-100">
                                <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">@L["Common.Date"]</th>
                                <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">@L["Common.Type"]</th>
                                <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">@L["Common.Amount"]</th>
                                <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">@L["Common.Balance"]</th>
                                <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">@L["Common.Note"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            @if (Model.BalanceHistory.Any())
                            {
                                @foreach (var b in Model.BalanceHistory)
                                {
                                    <tr class="table-row">
                                        <td class="px-5 py-3 text-gray-400 text-xs whitespace-nowrap">@b.RecordedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="px-5 py-3">
                                            <span class="badge @(b.Type == 0 ? "badge-success" : "badge-danger")">
                                                @(b.Type == 0 ? L["UserDetail.Credit"] : L["UserDetail.Withdrawal"])
                                            </span>
                                        </td>
                                        <td class="px-5 py-3 font-semibold text-sm @(b.Amount >= 0 ? "text-brand-600" : "text-red-500")">
                                            @(b.Amount >= 0 ? "+" : "")@b.Amount.ToString("N2") DA
                                        </td>
                                        <td class="px-5 py-3 text-gray-500 text-sm">@b.BalanceAfter.ToString("N2") DA</td>
                                        <td class="px-5 py-3 text-gray-400 text-xs max-w-xs truncate">@(b.Note ?? "")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="px-5 py-12 text-center">
                                        <i class="fas fa-clock text-gray-200 text-2xl mb-2"></i>
                                        <p class="text-sm text-gray-400">@L["Common.NoData"]</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- SMS Tab -->
        <div x-show="tab === 'sms'" x-transition>
            <div class="card">
                <div class="card-header flex items-center justify-between">
                    <h4 class="text-sm font-semibold text-gray-900">@L["ModemDetail.SmsMessages"]</h4>
                    <span class="text-xs text-gray-400">@Model.SmsMessages.Count @L["Dashboard.RecentSMS"]</span>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-gray-100">
                                <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">@L["Dashboard.Time"]</th>
                                <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">@L["Dashboard.Sender"]</th>
                                <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">@L["Dashboard.Content"]</th>
                                <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">@L["Dashboard.Modem"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            @if (Model.SmsMessages.Any())
                            {
                                @foreach (var sms in Model.SmsMessages)
                                {
                                    <tr class="table-row">
                                        <td class="px-5 py-3 text-gray-400 text-xs whitespace-nowrap">@sms.ReceivedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="px-5 py-3">
                                            <div class="flex items-center gap-2">
                                                <div class="w-7 h-7 bg-gray-100 rounded-full flex items-center justify-center text-[10px] font-bold text-gray-500 flex-shrink-0">
                                                    @(sms.SenderNumber.Length >= 2 ? sms.SenderNumber[^2..] : sms.SenderNumber)
                                                </div>
                                                <span class="font-medium text-xs">@sms.SenderNumber</span>
                                            </div>
                                        </td>
                                        <td class="px-5 py-3 text-gray-500 max-w-xs truncate text-xs">@sms.Content</td>
                                        <td class="px-5 py-3 text-gray-400 text-[11px]">@sms.PhoneNumber</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="px-5 py-12 text-center">
                                        <i class="fas fa-envelope text-gray-200 text-2xl mb-2"></i>
                                        <p class="text-sm text-gray-400">@L["ModemDetail.NoSms"]</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <!-- Withdrawal Modal -->
    <div id="withdrawalModal" class="hidden fixed inset-0 z-50 modal-overlay flex items-center justify-center p-4" onclick="if(event.target===this)this.classList.add('hidden')">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-sm">
            <div class="px-5 py-4 border-b border-gray-100">
                <h3 class="text-base font-semibold text-gray-900">@L["UserDetail.WithdrawalRequest"]</h3>
            </div>
            <form hx-post="/UserDetail?handler=CreateWithdrawal&userId=@Model.User.Id"
                  hx-swap="none"
                  class="p-5 space-y-4">
                <div>
                    <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">@L["UserDetail.Amount"] *</label>
                    <input type="number" name="amount" step="0.01" min="0.01" required class="input" placeholder="0.00" />
                    <p class="text-[11px] text-gray-400 mt-1">@L["UserDetail.Available"]: @Model.User.Balance.ToString("N2") DA</p>
                </div>
                <div>
                    <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">@L["UserDetail.NoteOptional"]</label>
                    <textarea name="note" rows="2" class="input" placeholder="@L["UserDetail.ReasonPlaceholder"]"></textarea>
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="submit" class="btn btn-primary flex-1">@L["UserDetail.CreateRequest"]</button>
                    <button type="button" onclick="document.getElementById('withdrawalModal').classList.add('hidden')" class="btn btn-outline">@L["Common.Cancel"]</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit User Modal -->
    <div id="editUserDetailModal" class="hidden fixed inset-0 z-50 modal-overlay flex items-center justify-center p-4" onclick="if(event.target===this)this.classList.add('hidden')">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-sm">
            <div class="px-5 py-4 border-b border-gray-100">
                <h3 class="text-base font-semibold text-gray-900">@L["Users.EditUser"]</h3>
            </div>
            <form hx-post="/UserDetail?handler=UpdateUser&userId=@Model.User.Id"
                  hx-swap="none"
                  hx-on::after-request="if(event.detail.successful){ document.getElementById('editUserDetailModal').classList.add('hidden'); }"
                  class="p-5 space-y-4">
                <div>
                    <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">@L["Common.Username"] *</label>
                    <input type="text" name="username" value="@Model.User.Username" required autocomplete="off" class="input" />
                </div>
                <div>
                    <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">@L["Users.EditDisplayName"]</label>
                    <input type="text" name="displayName" value="@Model.User.DisplayName" autocomplete="off" class="input" />
                </div>
                <div>
                    <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">@L["Users.EditNewPassword"]</label>
                    <input type="password" name="password" autocomplete="new-password" class="input" />
                </div>
                <div>
                    <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">@L["Users.EditConfirmPassword"]</label>
                    <input type="password" name="confirmPassword" autocomplete="new-password" class="input" />
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="submit" class="btn btn-primary flex-1">@L["Users.UpdateUser"]</button>
                    <button type="button" onclick="document.getElementById('editUserDetailModal').classList.add('hidden')" class="btn btn-outline">@L["Common.Cancel"]</button>
                </div>
            </form>
        </div>
    </div>
}
